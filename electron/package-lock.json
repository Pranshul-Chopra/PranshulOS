{
  "name": "pranshulos",
  "version": "2.1.0",
  "description": "PranshulOS \u2014 local-first desktop productivity shell",
  "main": "main.js",
  "author": "Pranshul Chopra",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win",
    "build:dir": "electron-builder build --win --dir"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "dev.pranshulchopra.pranshulos",
    "productName": "PranshulOS",
    "directories": {
      "output": "../release"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../flask-dist",
        "to": "flask",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signingHashAlgorithms": null,
      "sign": null
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PranshulOS"
    },
    "forceCodeSigning": false
  }
}